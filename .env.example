# Binance (use testnet credentials only for now)
BINANCE_API_KEY=your_testnet_key_here
BINANCE_API_SECRET=your_testnet_secret_here
BINANCE_TESTNET=true

# Trading config
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Postgres
# These values are used by Python scripts running on the HOST (poetry run …).
# The postgres container itself is initialised with the credentials hardcoded
# in docker-compose.yml (POSTGRES_USER=trader, POSTGRES_PASSWORD=test). They
# MUST match — change both together for any non-dev deployment.
POSTGRES_USER=trader
POSTGRES_PASSWORD=test
POSTGRES_DB=trading
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Airflow
# AIRFLOW__DATABASE__SQL_ALCHEMY_CONN runs INSIDE the docker network, so it
# uses postgres:5432 (internal hostname + internal port) — not the host mapping.
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://trader:test@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=generate_with_python_-c_from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Kafka
# Redpanda runs two listeners:
#   INTERNAL (redpanda:9092) — for services on the docker-internal network (Airflow, future containers)
#   EXTERNAL (localhost:19092) — for Python scripts running on the host
# Use the EXTERNAL value here; docker-internal services hardcode redpanda:9092.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_BOOTSTRAP_SERVERS_INTERNAL=redpanda:9092

# Reddit (Phase 4 — leave empty for now)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=
